{
  "version": 2,
  "functions": {
    "api/request-key.js": {
      "maxDuration": 10
    },
    "api/inference.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-API-Key, use-case-id" }
      ]
    }
  ]
}
